generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          String   @id @default(uuid())
  slug        String   @unique // URL-friendly identifier (e.g., 'frontend-developer-technova')
  title       String
  company     String
  location    String
  type        String
  category        String
  experienceLevel String   @default("Entry Level") // Entry Level, Mid Level, Senior, Lead
  salary          String   @default("Not specified")
  salaryMin       Float?
  salaryMax       Float?
  currency        String   @default("USD")
  workArrangement String   @default("Remote") // On-site, Remote, Hybrid
  applicationMethod String @default("Email") // URL, Email
  applicationValue  String @default("")
  expirationDate    DateTime?
  status          String   @default("Published") // Published, Draft, Closed
  description     String   @default("No description provided.")
  skills          String[] @default([])
  responsibilities String[] @default([])
  requirements    String[] @default([])
  
  // Timestamps
  postedAt    String // Keeping string to match "2 days ago" format from dummy data for now
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  applications Application[]

  @@index([slug])
}

model Application {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String?
  linkedin     String?
  portfolio    String?
  resumeUrl    String
  coverLetter  String?
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id])
  createdAt    DateTime @default(now())
}
